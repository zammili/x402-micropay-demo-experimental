# Quantum-Resistant x402 Micropay Demo Configuration
# Supports: Mainnet-Beta, Testnet, Devnet, Custom RPC

# ===== SOLANA NETWORK CONFIGURATION =====
# Choose one: mainnet-beta | testnet | devnet
SOLANA_CLUSTER=testnet

# RPC URL (auto-configured based on cluster, or override with custom)
# Mainnet: https://api.mainnet-beta.solana.com
# Testnet: https://api.testnet.solana.com
# Devnet: https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.testnet.solana.com

# ===== PAYMENT CONFIGURATION =====
SOLANA_PAYMENT_ADDRESS=YourTestnetSolanaWalletAddressHere
PRICE_SOL=0.001

# ===== VERIFICATION SETTINGS =====
# true: Verify payments on-chain via RPC
# false: Use mock verification (for development)
VERIFY_ONCHAIN=false

# Transaction validity window in seconds (default: 3600 = 1 hour)
TRANSACTION_VALIDITY_WINDOW=3600

# ===== QUANTUM CRYPTOGRAPHY =====
# Enable post-quantum cryptography (requires liboqs)
QUANTUM_ENABLED=true

# Hybrid mode: require both classical AND quantum signatures
# false: either/or (faster, still secure)
# true: belt-and-suspenders (slowest, maximum security)
USE_HYBRID_MODE=true

# Quantum algorithm: ML-KEM-768 | ML-DSA-65 | SPHINCS+
# ML-KEM-768: NIST FIPS 203 approved for key encapsulation
# ML-DSA-65: NIST FIPS 204 approved for signatures
# SPHINCS+: Hash-based stateless signature scheme
QUANTUM_ALGORITHM=ML-KEM-768

# Quantum keypair TTL in seconds (default: 86400 = 24 hours)
# After TTL, keys should be rotated for forward secrecy
QUANTUM_KEY_TTL=86400

# ===== SERVER CONFIGURATION =====
PORT=5002

# ===== LOGGING =====
LOG_LEVEL=INFO
